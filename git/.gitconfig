[user]
	name = ChrisAmora
	email = 27789416+ChrisAmora@users.noreply.github.com
[core]
	excludesfile = ~/.gitignore_global
	editor = nvim
	pager = delta
[pull]
	ff = only

[fetch]
	prune = true

[rebase]
	autosquash = true
[init]
	defaultBranch = main
[branch]
	sort = -committerdate
[alias]
	undo  = reset HEAD~1 --soft
	amend = commit --amend --no-edit
	lg    = log --oneline --graph --decorate -20
[diff]
	colorMoved = default
[push]
	autoSetupRemote = true
	default = current

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true
    light = false
    side-by-side = true
    line-numbers = true
    syntax-theme = Dracula
    hyperlinks = true

[merge]
    conflictstyle = zdiff3  ; requires git >= 2.35 — on WSL2/Ubuntu: sudo add-apt-repository ppa:git-core/ppa && sudo apt update && sudo apt install git
